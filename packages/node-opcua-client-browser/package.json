{
    "name": "node-opcua-client-browser",
    "version": "2.173.1",
    "description": "OPC UA SDK - browser WebSocket client (opc.ws / opc.wss)",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "browser": "./dist-esm/index.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "browser": "./dist-esm/index.js",
            "import": "./dist-esm/index.js",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "scripts": {
        "build": "tsc -b && tsc -p tsconfig.esm.json",
        "build:test-page": "node build-test-page.mjs",
        "lint": "eslint source test",
        "test:unit": "mocha",
        "test:e2e": "playwright test",
        "test": "pnpm test:unit && pnpm test:e2e",
        "test:check": "tsc --noEmit -p test/tsconfig.json",
        "clean": "npx rimraf -g node_modules dist dist-esm test/page/dist *.tsbuildinfo test-results playwright-report"
    },
    "dependencies": {
        "node-opcua-assert": "2.164.0",
        "node-opcua-client": "2.173.1",
        "node-opcua-common": "2.173.0",
        "node-opcua-crypto": "5.3.6",
        "node-opcua-debug": "2.172.0",
        "node-opcua-status-code": "2.173.0",
        "node-opcua-transport": "2.173.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@types/ws": "^8.18.1",
        "buffer": "^6.0.3",
        "esbuild": "^0.28.0",
        "events": "^3.3.0",
        "node-opcua-leak-detector": "2.172.0",
        "process": "^0.11.10",
        "util": "^0.12.5",
        "ws": "^8.20.1"
    },
    "author": "Sterfive SAS",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git://github.com/node-opcua/node-opcua.git"
    },
    "keywords": [
        "OPCUA",
        "opcua",
        "browser",
        "websocket",
        "wsopc-ua",
        "opc.ws",
        "opc.wss"
    ],
    "homepage": "http://node-opcua.github.io/",
    "files": [
        "dist",
        "dist-esm",
        "source"
    ],
    "gitHead": "064029878247adf2fa5d14a8124e1930431e2428"
}
