{
    "name": "node-opcua-mono-repo",
    "private": true,
    "description": "pure nodejs OPCUA SDK",
    "homepage": "http://node-opcua.github.io/",
    "main": "index.js",
    "bin": {},
    "directories": {
        "test": "test"
    },
    "scripts": {
        "fix:tsconfigs": "pnpm --filter \"./packages/node-opcua-*\" exec fix-tsconfigs",
        "extract:dep": "pnpm exec grep -RhoP 'from\\s+\"\\Knode-opcua[^\"]+' source | sort | uniq",
        "tsup": "npx tsup ./packages/node-opcua/source/index.ts",
        "consistency": "npx -y @ster5/check-version-consistency",
        "preinstall": "node prevent_npm_install.js",
        "postinstall": "pnpm build",
        "_x_preinstall": "npm i browserify -g",
        "build": "npm run generate && tsc -b packages",
        "generate": "pnpm --filter node-opcua-types run generate && pnpm --filter \"!node-opcua-types\" recursive run generate",
        "pretest": "pnpm recursive run pretest",
        "test": "cd packages && node --expose-gc ${SECURITY_REVERT_CVE_2023_46809} --max-old-space-size=2048 run_all_mocha_tests.js",
        "test:parallel": "cd packages && node parallel_test.js",
        "test:win": "cd packages && node --expose-gc --max-old-space-size=2048 run_all_mocha_tests.js",
        "generate_doc": "make doc",
        "generate_autodoc": "npx autodoc -o _tmp_generated_doc bin/binaryStream.js",
        "ncu": "ncu -u -x yargs,env-paths,long,@types/long,cli-truncate,chalk,case-anything,@types/node,typescript --target=latest && ncu --deep -u --timeout 400000  -x yargs,env-paths,cli-truncate,chalk,case-anything,long,@types/long,@types/node,typescript --target=latest ",
        "ncu:minor": "npx npm-check-updates  -u  --deep --target=minor",
        "prettier-watch": "onchange \"packages/*/(src|test|source)/**/*.(js|ts)\" -v -p -- prettier --write {{changed}}",
        "alex": "npx alex documentation/*.md",
        "cost-of-modules": "npx cost-of-modules",
        "typedoc": "npx typedoc --tsconfig tsconfig-for-doc.json --options typedoc.json",
        "typedoc:all": "npx typedoc --mode library --options typedoc.json",
        "legal": "npx legally",
        "legal2": "npx npm-license-crawler",
        "legal3": " npx license-checker --production --summary",
        "version:lerna": "pnpm m run clean && npx rimraf -g packages/node_modules packages/*/dist  packages/*/\"tsconfig.tsbuildinfo\" && pnpm m i && npx lerna version",
        "makelinks": "npx tsx ../make-links/makelinks.ts",
        "clean": "node tools/clean/clean.js",
        "postversion": "pnpm m install"
    },
    "repository": {
        "type": "git",
        "url": "git://github.com/node-opcua/node-opcua.git"
    },
    "keywords": [
        "OPCUA",
        "opcua",
        "m2m",
        "iot",
        "opc ua",
        "internet of things"
    ],
    "author": "Etienne Rossignon",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/node-opcua/node-opcua/issues"
    },
    "workspaces": [
        "tools/*",
        "packages/*",
        "packages_extra/*"
    ],
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@types/mocha": "^10.0.10",
        "@types/node": "24.12.2",
        "app-module-path": "^2.2.0",
        "benchmark": "^2.1.4",
        "bignumber.js": "^11.1.1",
        "csv": "^6.5.1",
        "enum": "3.0.4",
        "ersatz-node-expat": "^0.1.6",
        "json5": "^2.2.3",
        "mocha": "12.0.0-beta-9.2",
        "mocha-lcov-reporter": "^1.3.0",
        "prettier": "^3.8.3",
        "should": "^13.2.3",
        "source-map-support": "^0.5.21",
        "tsx": "^4.21.0",
        "typescript": "5.9.3"
    },
    "typings": "./packages/node-opcua/node-opcua.d.ts",
    "engines": {
        "node": ">=22.13.0",
        "pnpm": ">=11.0.0"
    },
    "packageManager": "pnpm@11.1.1",
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    },
    "dependenciesMeta": {
        "*": {
            "injected": true
        }
    },
    "dependencies": {
        "@ster5/global-mutex": "^3.3.0",
        "@sterfive/fix-tsconfigs": "1.0.0",
        "@types/async": "3.2.25",
        "@types/bonjour": "^3.5.13",
        "@types/lodash.partition": "^4.6.9",
        "@types/lodash.sortby": "^4.7.9",
        "@types/long": "4.0.2",
        "@types/sinon": "21.0.1",
        "@types/underscore": "1.13.0",
        "@types/wordwrap": "^1.0.3",
        "@types/yargs": "17.0.35",
        "backoff": "^2.5.0",
        "bomstrip": "^0.1.4",
        "chalk": "4.1.2",
        "cli-table3": "0.6.5",
        "cli-truncate": "2.1.0",
        "csv-parse": "6.2.1",
        "dequeue": "^1.0.5",
        "easy-table": "^1.2.0",
        "env-paths": "2.2.1",
        "hexy": "0.4.0",
        "humanize": "0.0.9",
        "lodash.partition": "^4.6.0",
        "lodash.sortby": "^4.7.0",
        "long": "5.3.2",
        "memfs": "^4.57.2",
        "mocha-clean": "^1.0.0",
        "node-opcua-crypto": "5.3.6",
        "node-opcua-pki": "6.17.0",
        "rimraf": "^6.1.3",
        "semver": "^7.8.0",
        "sinon": "^22.0.0",
        "sprintf-js": "^1.1.3",
        "sterfive-bonjour-service": "1.1.4",
        "thenify-ex": "4.4.0",
        "treeify": "^1.1.0",
        "tsconfig-paths": "^4.2.0",
        "tslib": "^2.8.1",
        "winston": "*",
        "wordwrap": "^1.0.0",
        "xml-writer": "^1.7.0",
        "yargs": "15.4.1"
    },
    "funding": {
        "url": "https://github.com/sponsors/erossignon"
    }
}